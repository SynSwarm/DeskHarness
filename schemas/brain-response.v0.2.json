{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deskharness.dev/schemas/brain-response.v0.2.json",
  "title": "BrainResponse",
  "type": "object",
  "required": ["response_version", "trace_id", "decision"],
  "properties": {
    "response_version": { "type": "string", "const": "0.2" },
    "trace_id": { "type": "string" },
    "decision": {
      "type": "object",
      "required": ["intent"],
      "properties": {
        "target": {
          "type": "object",
          "properties": {
            "statement": { "type": "string" },
            "success_criteria": { "type": "string" }
          }
        },
        "intent": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "entities": { "type": "object" },
        "plan": {
          "type": "object",
          "properties": {
            "mode": { "type": "string", "enum": ["single", "sequential"] },
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["plugin_id", "command"],
                "properties": {
                  "plugin_id": { "type": "string" },
                  "command": { "type": "string" },
                  "params": { "type": "object" }
                }
              }
            }
          }
        },
        "reply": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "text": { "type": "string" }
          }
        }
      }
    }
  }
}
