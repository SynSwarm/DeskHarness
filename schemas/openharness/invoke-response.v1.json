{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deskharness.dev/schemas/openharness/invoke-response.v1.json",
  "title": "OpenHarness Invoke Response (OH-1 subset)",
  "type": "object",
  "required": ["protocol_version", "request_id", "response"],
  "additionalProperties": true,
  "properties": {
    "protocol_version": { "type": "string" },
    "request_id": { "type": "string" },
    "supported_protocol_versions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "response": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": true,
      "properties": {
        "status": { "type": "string", "enum": ["success", "partial", "failure"] },
        "action_directives": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["action_type"],
            "properties": {
              "action_type": { "type": "string" },
              "payload": { "type": "object" }
            }
          }
        }
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" },
        "details": { "type": "object" }
      }
    }
  }
}
